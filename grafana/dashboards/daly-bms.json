      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(daly_bms_http_requests_total[$__rate_interval])", "legendFormat": "{{endpoint}} {{status}}", "refId": "A" } ]
    },

    { "type": "row", "id": 50, "title": "Health — imbalance, SOH & energy", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 68 } },

    {
      "type": "stat", "id": 51, "title": "SOH (est) %",
      "description": "SOH ≈ full-charge capacity / rated. Estimated from remaining/SOC — approximate for LTO (flat OCV curve); most reliable near full charge. EOL ~80%.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 69 },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 80 }, { "color": "green", "value": 90 } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value_and_name" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "daly_bms_remaining_capacity_amp_hours{sn=~\"$sn\"} / (daly_bms_soc_percent{sn=~\"$sn\"}/100) / daly_bms_rated_capacity_amp_hours{sn=~\"$sn\"} * 100 and on(sn) (daly_bms_soc_percent{sn=~\"$sn\"} > 20)", "legendFormat": "{{sn}}", "refId": "A" } ]
    },
    {
      "type": "stat", "id": 52, "title": "C-rate",
      "description": "Charge/discharge current relative to rated capacity (I/C). >0 charge, <0 discharge.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 69 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null }, { "color": "green", "value": 0 } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value_and_name" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "daly_bms_current_amperes{sn=~\"$sn\"} / daly_bms_rated_capacity_amp_hours{sn=~\"$sn\"}", "legendFormat": "{{sn}}", "refId": "A" } ]
    },
    {
      "type": "stat", "id": 53, "title": "UV headroom (mV)",
      "description": "Weakest cell voltage minus its under-voltage protection threshold. Thresholds preliminary — tune after baseline.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 69 },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 50 }, { "color": "green", "value": 150 } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value_and_name" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "(daly_bms_cell_voltage_min_volts{sn=~\"$sn\"} - on(sn) daly_bms_cell_voltage_low_limit_volts{sn=~\"$sn\",level=\"protection\"}) * 1000", "legendFormat": "{{sn}}", "refId": "A" } ]
    },
    {
      "type": "stat", "id": 54, "title": "OV headroom (mV)",
      "description": "Over-voltage protection threshold minus strongest cell voltage. Thresholds preliminary.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 69 },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 50 }, { "color": "green", "value": 150 } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value_and_name" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "(daly_bms_cell_voltage_high_limit_volts{sn=~\"$sn\",level=\"protection\"} - on(sn) daly_bms_cell_voltage_max_volts{sn=~\"$sn\"}) * 1000", "legendFormat": "{{sn}}", "refId": "A" } ]
    },
    {
      "type": "stat", "id": 55, "title": "Time to full (h)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 69 },
      "fieldConfig": { "defaults": { "unit": "h", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value_and_name" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "(daly_bms_rated_capacity_amp_hours{sn=~\"$sn\"} - daly_bms_remaining_capacity_amp_hours{sn=~\"$sn\"}) / daly_bms_current_amperes{sn=~\"$sn\"} and on(sn) (daly_bms_current_amperes{sn=~\"$sn\"} > 0)", "legendFormat": "{{sn}}", "refId": "A" } ]
    },
    {
      "type": "stat", "id": 56, "title": "Time to empty (h)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 69 },
      "fieldConfig": { "defaults": { "unit": "h", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value_and_name" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "daly_bms_remaining_capacity_amp_hours{sn=~\"$sn\"} / (- daly_bms_current_amperes{sn=~\"$sn\"}) and on(sn) (daly_bms_current_amperes{sn=~\"$sn\"} < 0)", "legendFormat": "{{sn}}", "refId": "A" } ]
    },
    {
      "type": "stat", "id": 57, "title": "Charged (Ah, range)",
      "description": "Coulomb-counted charge throughput over the dashboard time range (increase() handles counter resets on restart).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 73 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value_and_name" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "increase(daly_bms_charge_amp_hours_total{sn=~\"$sn\"}[$__range])", "legendFormat": "{{sn}}", "refId": "A" } ]
    },
    {
      "type": "stat", "id": 58, "title": "Discharged (Ah, range)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 73 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value_and_name" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "increase(daly_bms_discharge_amp_hours_total{sn=~\"$sn\"}[$__range])", "legendFormat": "{{sn}}", "refId": "A" } ]
    },
    {
      "type": "stat", "id": 59, "title": "Net (Ah, range)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 73 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "orange", "value": null }, { "color": "green", "value": 0 } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value_and_name" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "increase(daly_bms_charge_amp_hours_total{sn=~\"$sn\"}[$__range]) - increase(daly_bms_discharge_amp_hours_total{sn=~\"$sn\"}[$__range])", "legendFormat": "{{sn}}", "refId": "A" } ]
    },
    {
      "type": "stat", "id": 60, "title": "Coulombic eff (range) %",
      "description": "Discharge Ah / charge Ah over the range. Meaningful over full charge/discharge cycles.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 5, "x": 15, "y": 73 },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value_and_name" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "increase(daly_bms_discharge_amp_hours_total{sn=~\"$sn\"}[$__range]) / increase(daly_bms_charge_amp_hours_total{sn=~\"$sn\"}[$__range]) * 100", "legendFormat": "{{sn}}", "refId": "A" } ]
    },
    {
      "type": "stat", "id": 61, "title": "Equiv. full cycles (range)",
      "description": "Discharge throughput / rated capacity — throughput-based cycle count (independent of the BMS cycle counter).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 73 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 2, "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value_and_name" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "increase(daly_bms_discharge_amp_hours_total{sn=~\"$sn\"}[$__range]) / daly_bms_rated_capacity_amp_hours{sn=~\"$sn\"}", "legendFormat": "{{sn}}", "refId": "A" } ]
    },
    {
      "type": "timeseries", "id": 62, "title": "Cumulative Ah (in/out)",
      "description": "Raw coulomb counters (reset to 0 on exporter restart — expected).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 77 },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "daly_bms_charge_amp_hours_total{sn=~\"$sn\"}", "legendFormat": "{{sn}} charged", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "daly_bms_discharge_amp_hours_total{sn=~\"$sn\"}", "legendFormat": "{{sn}} discharged", "refId": "B" }
      ]
    },
    {
      "type": "timeseries", "id": 63, "title": "Ah throughput (avg A)",
      "description": "rate() of the coulomb counters × 3600 = average current per direction.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 77 },
      "fieldConfig": { "defaults": { "unit": "amp", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(daly_bms_charge_amp_hours_total{sn=~\"$sn\"}[$__rate_interval]) * 3600", "legendFormat": "{{sn}} charge", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(daly_bms_discharge_amp_hours_total{sn=~\"$sn\"}[$__rate_interval]) * 3600", "legendFormat": "{{sn}} discharge", "refId": "B" }
      ]
    },
    {
      "type": "timeseries", "id": 64, "title": "Cell stddev (mV)",
      "description": "Standard deviation of cell voltages — pack inconsistency. Rising trend = growing imbalance/degradation. Thresholds preliminary.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 77 },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 20, "showPoints": "never", "thresholdsStyle": { "mode": "line" } }, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 40 }, { "color": "red", "value": 80 } ] } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "stddev by (sn) (daly_bms_cell_voltage_volts{sn=~\"$sn\"}) * 1000", "legendFormat": "{{sn}}", "refId": "A" } ]
    },
    {
      "type": "timeseries", "id": 65, "title": "Imbalance vs balancing",
      "description": "Cell spread (mV, left) and balancer duty cycle over 1h (%, right). Does balancing reduce the spread?",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 85 },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [ { "matcher": { "id": "byRegexp", "options": ".*duty.*" }, "properties": [ { "id": "unit", "value": "percent" }, { "id": "custom.axisPlacement", "value": "right" }, { "id": "custom.fillOpacity", "value": 0 } ] } ] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "daly_bms_cell_voltage_delta_volts{sn=~\"$sn\"} * 1000", "legendFormat": "{{sn}} delta (mV)", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "avg_over_time(daly_bms_balancer_active{sn=~\"$sn\"}[1h]) * 100", "legendFormat": "{{sn}} balancer duty", "refId": "B" }
      ]
    },

    { "type": "row", "id": 70, "title": "Health per cell — $sn", "collapsed": false, "repeat": "sn", "repeatDirection": "h", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 93 } },

    {
      "type": "bargauge", "id": 71, "title": "Cell deviation from mean (mV) — $sn",
      "description": "Per-cell voltage minus pack average. Negative = weak/sagging cell (relative internal resistance / weaker cell).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 94 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1, "color": { "mode": "continuous-GrYlRd" } }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "basic", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" }, "showUnfilled": true },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "(daly_bms_cell_voltage_volts{sn=\"$sn\"} - on(sn) group_left() daly_bms_cell_voltage_avg_volts{sn=\"$sn\"}) * 1000", "legendFormat": "cell {{cell}}", "refId": "A", "instant": true } ]
    },
    {
      "type": "timeseries", "id": 72, "title": "Cell drift from mean (mV) — $sn",
      "description": "Deviation over time — a cell that steadily drifts away is aging/weakening.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 94 },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 0, "showPoints": "never", "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "min", "max"] }, "tooltip": { "mode": "multi", "sort": "asc" } },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "(daly_bms_cell_voltage_volts{sn=\"$sn\"} - on(sn) group_left() daly_bms_cell_voltage_avg_volts{sn=\"$sn\"}) * 1000", "legendFormat": "cell {{cell}}", "refId": "A" } ]
    },
    {
      "type": "table", "id": 73, "title": "Cell ranking — $sn",
      "description": "Cells sorted by voltage (weakest at top).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 94 },
      "fieldConfig": { "defaults": { "unit": "volt", "decimals": 3 }, "overrides": [] },
      "options": { "showHeader": true },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "daly_bms_cell_voltage_volts{sn=\"$sn\"}", "format": "table", "instant": true, "refId": "A" } ],
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true, "sn": true }, "renameByName": { "cell": "cell", "Value": "voltage" } } },
        { "id": "sortBy", "options": { "fields": {}, "sort": [ { "field": "voltage", "desc": false } ] } }
      ]
    },

    { "type": "row", "id": 80, "title": "LTO diagnostics — $sn", "collapsed": false, "repeat": "sn", "repeatDirection": "h", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 102 } },

    {
      "type": "table", "id": 81, "title": "Top-of-charge ranking (mV, ~30d) — $sn",
      "description": "Per-cell average deviation from mean while SOC>95%. LTO's flat curve hides weak cells mid-SOC; at top-of-charge the capacity-limited cell fills first and rides highest. Highest value = replace-first candidate (on charge). Window is a subquery lookback, not the dashboard range.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 103 },
