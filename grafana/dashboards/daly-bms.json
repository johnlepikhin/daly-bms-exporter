      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(daly_bms_frames_dropped_total[$__rate_interval])", "legendFormat": "{{reason}}", "refId": "A" } ]
    },
